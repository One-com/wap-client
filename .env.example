# PostgreSQL
DATABASE_URL=postgresql://wap:wap@localhost:5432/wap

# Redis
REDIS_URL=redis://localhost:6379

# Session encryption — 32 bytes, base64-encoded
# Generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SESSION_ENCRYPTION_KEY=

# Admin API (protect /admin/* routes)
ADMIN_API_KEY=change-me-in-production

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Must be the base URL only — no /v1 suffix (the SDK appends it automatically)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Conversation summarization — compress a thread once it exceeds this many messages (default 20)
SUMMARIZER_MESSAGE_THRESHOLD=20

# External product license validation APIs
WP_ROCKET_LICENSE_API_URL=https://wp-rocket.me/api/v1/validate
RANKMATH_LICENSE_API_URL=https://rankmath.com/api/v1/validate

# Dev: set to "true" to skip external license validation (NEVER use in production)
DEV_BYPASS_LICENSE=true
# Dev: set to "true" to skip WP App Password validation — useful when the WP site
# is unreachable from inside Docker (e.g. Local by Flywheel). (NEVER use in production)
DEV_BYPASS_WP_CHECK=true
AUTH_SITE_ALLOWLIST_ENABLED=true

# LangFuse observability (optional — omit to disable tracing)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=

# Sentry error tracking (optional — omit DSN to disable)
SENTRY_DSN=
# Fraction of transactions to send as performance traces (0.0–1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics (optional — set to true to expose /metrics endpoint)
PROMETHEUS_ENABLED=false
