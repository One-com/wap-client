{
    "name": "group-one/wap-client",
    "description": "WordPress AI Platform (WAP) client library — drop-in Composer package for integrating AI chat into any WordPress plugin.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Group.one",
            "homepage": "https://www.group.one"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "GroupOne\\WapClient\\": "includes/"
        },
        "files": [
            "wap-client.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "GroupOne\\WapClient\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "wordpress",
        "ai",
        "chat",
        "group-one",
        "wap"
    ]
}
